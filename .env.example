# CertiFoto — variables de entorno (todas opcionales)
# Copia este archivo a .env.local y descomenta lo que necesites.
# .env.local esta en .gitignore — nunca lo commitees.

# === Analytics ===
# Vercel Analytics es automatico en deploys de Vercel.
# Si quieres analytics en otro hosting, descomenta:
# NEXT_PUBLIC_ANALYTICS_ID=

# === URL canonica del sitio ===
# Por defecto se infiere. Util para SEO en sitemap y Open Graph.
NEXT_PUBLIC_SITE_URL=https://certifoto.cl

# === Email de contacto ===
# Mostrado en /contacto, footer y politica de privacidad.
NEXT_PUBLIC_CONTACT_EMAIL=contacto@certifoto.cl

# === Servicios futuros (no requeridos hoy) ===
# RESEND_API_KEY=                   Para enviar emails desde el formulario de contacto
# SENTRY_DSN=                       Error tracking
# OPENAI_API_KEY=                   Si se reemplaza el AI stub por IA real
